# ============================================================
# GhostTrace AI — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Application ─────────────────────────────────────────────
NODE_ENV=development
PORT=3001
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3000,https://ghosttrace-ai.run.app

# ── MongoDB Atlas ────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=ghosttrace
MONGODB_CHANGE_STREAM_FULL_DOC=updateLookup

# ── Google Cloud / Gemini ────────────────────────────────────
GOOGLE_CLOUD_PROJECT=<your-gcp-project-id>
GOOGLE_CLOUD_REGION=us-central1
GEMINI_MODEL=gemini-3.0-pro
GEMINI_EMBEDDING_MODEL=gemini-embedding-3.0
GEMINI_MAX_OUTPUT_TOKENS=2048
GEMINI_TEMPERATURE=0.1
EXTERNAL_ENFORCEMENT_URL=
EXTERNAL_ENFORCEMENT_SECRET=
GOOGLE_APPLICATION_CREDENTIALS=/secrets/gcp-sa-key.json

# ── Google Cloud Agent Builder ───────────────────────────────
AGENT_BUILDER_PROJECT=<your-gcp-project-id>
AGENT_BUILDER_LOCATION=us-central1
AGENT_BUILDER_AGENT_ID=<your-agent-id>

# ── MCP (Model Context Protocol) ────────────────────────────
MCP_SERVER_PORT=3002
MCP_TRANSPORT=http
MCP_AUTH_SECRET=<generate-strong-random-secret>
MCP_TOOL_TIMEOUT_MS=10000

# ── WebSocket / Real-time ────────────────────────────────────
WS_PING_INTERVAL_MS=25000
WS_PING_TIMEOUT_MS=60000
WS_MAX_CONNECTIONS=1000

# ── Agent Thresholds ─────────────────────────────────────────
FRAUD_SCORE_BLOCK_THRESHOLD=80
FRAUD_SCORE_FLAG_THRESHOLD=50
FRAUD_SCORE_REVIEW_THRESHOLD=65
AGENT_CONFIDENCE_MIN=0.7
MAX_VELOCITY_PER_MINUTE=10
GEO_ANOMALY_KM_THRESHOLD=2000

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ── Notifications (optional) ─────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alerts@yourdomain.com
SMTP_PASS=<smtp-app-password>
ALERT_EMAIL_RECIPIENTS=admin@yourdomain.com

SLACK_WEBHOOK_URL=https://hooks.slack.com/services/<your-webhook>

# ── Auth / Security ──────────────────────────────────────────
JWT_SECRET=<generate-256-bit-random-secret>
JWT_EXPIRES_IN=8h
API_KEY_HASH=<sha256-of-your-api-key>
ENCRYPTION_KEY=<32-byte-hex-key-for-data-masking>

# ── Cloud Run ────────────────────────────────────────────────
CLOUD_RUN_SERVICE_URL=https://ghosttrace-ai-<hash>-uc.a.run.app
