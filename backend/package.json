{
  "name": "ghosttrace-backend",
  "version": "1.0.0",
  "description": "GhostTrace AI — Backend fraud detection engine",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon --watch src --ext js src/index.js",
    "start": "node src/index.js",
    "build": "echo 'No build step for Node.js backend'",
    "test": "jest --runInBand --forceExit",
    "test:unit": "jest tests/unit --runInBand --forceExit",
    "test:integration": "jest tests/integration --runInBand --forceExit",
    "test:simulation": "jest tests/simulation --runInBand --forceExit",
    "test:coverage": "jest --coverage --runInBand --forceExit",
    "lint": "eslint src --ext .js"
  },
  "dependencies": {
    "@google-cloud/secret-manager": "^5.6.0",
    "@google/generative-ai": "^0.21.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.3.2",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.7.0",
    "morgan": "^1.10.1",
    "nodemailer": "^8.0.7",
    "pino": "^9.14.0",
    "pino-pretty": "^11.3.0",
    "socket.io": "^4.8.3",
    "uuid": "^10.0.0",
    "winston": "^3.19.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/jest": "^29.5.13",
    "jest": "^29.7.0",
    "nodemon": "^3.1.7",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000,
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/index.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 80,
        "lines": 80
      }
    }
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
