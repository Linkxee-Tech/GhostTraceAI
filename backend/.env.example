# ============================================================
# GhostTrace AI — Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Application ─────────────────────────────────────────────
NODE_ENV=development
PORT=3001
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3000
ALLOW_VERCEL_PREVIEW_ORIGINS=false

# ── MongoDB Atlas ────────────────────────────────────────────
# Get your URI from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=ghosttrace
MONGODB_CHANGE_STREAM_FULL_DOC=updateLookup

# ── Google AI (Gemini) ───────────────────────────────────────
# Get your API key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIza...
GEMINI_MODEL=gemini-3.0-pro
GEMINI_EMBEDDING_MODEL=gemini-embedding-3.0
GEMINI_MAX_OUTPUT_TOKENS=2048
GEMINI_TEMPERATURE=0.1
EXTERNAL_ENFORCEMENT_URL=
EXTERNAL_ENFORCEMENT_SECRET=

# ── Google Cloud (for Agent Builder) ─────────────────────────
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_REGION=us-central1
AGENT_BUILDER_AGENT_ID=your-agent-id

# ── Auth & Security ──────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-256-bit-random-secret
JWT_EXPIRES_IN=8h

# Generate API key hash with:
# node -e "const c=require('crypto'); const k='your-api-key'; console.log(c.createHash('sha256').update(k).digest('hex'))"
API_KEY_HASH=sha256-hash-of-your-api-key

# Set to 'true' only for local development debug sessions.
# Keep this 'false' for any shared/staging/production environment.
BYPASS_AUTH=false

# ── MCP (Model Context Protocol) ────────────────────────────
MCP_SERVER_PORT=3002
MCP_AUTH_SECRET=your-mcp-secret
MCP_TOOL_TIMEOUT_MS=10000

# ── WebSocket ────────────────────────────────────────────────
WS_PING_INTERVAL_MS=25000
WS_PING_TIMEOUT_MS=60000

# ── Agent Thresholds ─────────────────────────────────────────
FRAUD_SCORE_BLOCK_THRESHOLD=80
FRAUD_SCORE_FLAG_THRESHOLD=50
FRAUD_SCORE_REVIEW_THRESHOLD=65
AGENT_CONFIDENCE_MIN=0.7
MAX_VELOCITY_PER_MINUTE=10
GEO_ANOMALY_KM_THRESHOLD=2000

# ── Notifications (optional) ─────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alerts@yourdomain.com
SMTP_PASS=your-app-password
ALERT_EMAIL_RECIPIENTS=admin@yourdomain.com

# Get from: https://api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
